# Firebase web app configuration. Copy to .env and fill in with your project values.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Cloudinary unsigned upload for portrait images.
# Create an unsigned upload preset in your Cloudinary console (Settings > Upload).
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
# Optional: folder to store uploaded portraits in.
VITE_CLOUDINARY_FOLDER=beacon-portraits
